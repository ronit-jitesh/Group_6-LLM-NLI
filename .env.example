# NLI Project Environment Variables
# ================================

# 1. API Keys (required)
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GROQ_API_KEY=your_groq_key_here

# 2. Local Paths (optional)
# If not set, scripts will attempt to find MultiNLI in ../LLM/NLI/
MULTINLI_DIR=/path/to/multinli_1.0
